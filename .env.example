# Backend API URL
VITE_BACKEND_URL=http://localhost:8000

# Optional OpenAI settings for local AI generation
# Put these in backend/.env when running the Python backend.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Free no-key AI fallback for showcase mode
FREE_AI_ENABLED=true
ONE_GENERATION_PER_CLIENT=true
